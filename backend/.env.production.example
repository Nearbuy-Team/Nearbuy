# Copy this file to .env.production on the server. Never commit the real file.
API_DOMAIN=api.your-domain.com
CORS_ALLOWED_ORIGIN_PATTERNS=https://your-web-app.example.com

POSTGRES_DB=nearbuy_db
POSTGRES_USER=nearbuy
POSTGRES_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-at-least-64-random-characters
JWT_ISSUER=nearbuy-api
JWT_EXPIRATION=86400000

# Use sk_test_ first. Change to sk_live_ only after test transactions and payouts pass.
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_CALLBACK_URL=https://api.your-domain.com/api/payments/paystack/callback

# SMTP provider values for real OTP email delivery.
OTP_FROM=no-reply@your-domain.com
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=replace_me
MAIL_PASSWORD=replace_me

EXPO_PUSH_ENABLED=true
