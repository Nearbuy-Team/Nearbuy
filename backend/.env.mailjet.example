# Copy these values into backend/.env. Never commit the real API keys.
OTP_DELIVERY=mailjet
OTP_FROM=your-verified-sender@example.com
OTP_FROM_NAME=Nearbuy
MAILJET_API_KEY=replace_with_your_mailjet_api_key
MAILJET_SECRET_KEY=replace_with_your_mailjet_secret_key
MAILJET_API_URL=https://api.mailjet.com/v3.1/send
